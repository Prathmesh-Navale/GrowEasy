{
  "name": "groweasy-csv-importer",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
"scripts": {
  "dev": "concurrently \"pnpm --dir backend dev\" \"pnpm --dir frontend dev\"",
  "build": "pnpm --dir backend build && pnpm --dir frontend build",
  "start": "pnpm --dir backend start",
  "backend:build": "pnpm --dir backend build",
  "frontend:build": "pnpm --dir frontend build",
  "prisma:generate": "pnpm --dir backend exec prisma generate --schema ../prisma/schema.prisma"
},
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prisma": "^4.16.2"
  },
  "dependencies": {
    "@prisma/client": "^4.16.2"
  }
}
